# Slack app credentials (see Phase 0 in build spec)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_CHANNEL_ID=C01234567

# Optional overrides (defaults shown)
#TENANTS_CONFIG_PATH=./tenants.toml
#AUDIT_DB_PATH=./data/audit.db
#ROLLBACK_WINDOW_SECONDS=300
#LOG_LEVEL=INFO
#HTTP_TIMEOUT_SECONDS=10

# One entry per tenant, named by api_key_env_var in tenants.toml
# (Mailgun private API key; the tenant's domain lives in tenants.toml)
TEST_BRAND_MAILGUN_API_KEY=your-mailgun-private-key
